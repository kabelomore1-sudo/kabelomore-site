# Resend API key for the /api/scan endpoint to email new lead requests directly.
# Without this, scan submissions still succeed and are logged to Vercel logs.
# Get one at https://resend.com — free tier covers 100 emails/day.
RESEND_API_KEY=re_xxx

# Where new scan requests are sent (defaults to kabelo@kabelomore.com)
SCAN_INBOX_EMAIL=kabelo@kabelomore.com

# The "From" address (must be verified in Resend before use)
SCAN_FROM_EMAIL=scan@kabelomore.com
