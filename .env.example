# Resend API key for the /api/scan endpoint to email new lead requests directly.
# Without this, scan submissions still succeed and are logged to Vercel logs.
# Get one at https://resend.com — free tier covers 100 emails/day.
RESEND_API_KEY=re_xxx

# Where new scan requests are sent (defaults to kabelo@kabelomore.com)
SCAN_INBOX_EMAIL=kabelo@kabelomore.com

# The "From" address (must be verified in Resend before use)
SCAN_FROM_EMAIL=scan@kabelomore.com

# Google Analytics 4 Measurement ID — used by @next/third-parties/google <GoogleAnalytics />
# Get yours at analytics.google.com → Admin → Data Streams → your web stream
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Admin dashboard auth ─────────────────────────────────────────
# Shared bearer token protecting /admin/* and /api/admin/*. Single
# admin (Kabelo), not a multi-user system.
# REQUIREMENTS:
#   - Minimum 24 characters, random. Generate with: openssl rand -hex 24
#   - NO leading/trailing whitespace or newline. A trailing newline
#     pasted from a password manager / `vercel env add` silently breaks
#     every login (the value is now trimmed defensively, but keep it
#     clean). Set it in Vercel → Settings → Environment Variables
#     (Production scope) and REDEPLOY — env changes don't apply to an
#     already-running deployment.
ADMIN_TOKEN=replace-with-openssl-rand-hex-24-output

# ─── Anthropic (scan engine) ──────────────────────────────────────
# Required for the Claude + web_search scan pipeline. Without it the
# admin "Run scan" endpoint returns 503.
ANTHROPIC_API_KEY=sk-ant-xxx

# ─── Vercel KV / Upstash Redis (scan storage) ─────────────────────
# Backs scan profiles, results, status, the submission index, and the
# admin workflow flags. If unset, the admin dashboard renders its
# "KV unconfigured" error state instead of submissions.
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=xxx

# ─── Google Places (GBP signal — optional) ────────────────────────
# Enables the Places-backed GBP signals (rating, reviews, categories,
# hours) in the scan. Optional: the scan degrades gracefully and the
# gbpLookup stage is marked "skipped" if absent.
GOOGLE_PLACES_API_KEY=xxx
